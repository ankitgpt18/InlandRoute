# =============================================================================
# AIDSTL API — Environment Variables
# "Predicting Inland Waterway Navigability Using Satellite Remote Sensing
#  and Deep Learning"
#
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------

# Application display name
APP_NAME="AIDSTL API"

# Semantic version of the API
APP_VERSION="1.0.0"

# Enable debug mode (set to False in production)
DEBUG=False

# Secret key used for signing tokens — generate with:
#   python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=your_super_secret_key_change_me_in_production

# JWT algorithm
ALGORITHM=HS256

# Access token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60


# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL + PostGIS)
# -----------------------------------------------------------------------------

# Full async DSN — replace credentials and host as needed
DATABASE_URL=postgresql+asyncpg://aidstl_user:aidstl_password@localhost:5432/aidstl_db

# Synchronous DSN used by Alembic migrations
SYNC_DATABASE_URL=postgresql+psycopg2://aidstl_user:aidstl_password@localhost:5432/aidstl_db

# Individual components (used by docker-compose)
POSTGRES_DB=aidstl_db
POSTGRES_USER=aidstl_user
POSTGRES_PASSWORD=aidstl_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# SQLAlchemy connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30


# -----------------------------------------------------------------------------
# REDIS
# -----------------------------------------------------------------------------

# Redis connection URL
REDIS_URL=redis://localhost:6379/0

# Default cache TTL in seconds (6 hours)
CACHE_TTL_SECONDS=21600


# -----------------------------------------------------------------------------
# CELERY (Task Queue)
# -----------------------------------------------------------------------------

# Broker — points at Redis
CELERY_BROKER_URL=redis://localhost:6379/1

# Result backend — points at Redis
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Concurrency level for Celery workers
CELERY_WORKER_CONCURRENCY=4

# Maximum tasks per child process before restart
CELERY_MAX_TASKS_PER_CHILD=100


# -----------------------------------------------------------------------------
# GOOGLE EARTH ENGINE (GEE)
# -----------------------------------------------------------------------------

# Service account email registered with GEE
# Create at: https://console.cloud.google.com/iam-admin/serviceaccounts
GEE_SERVICE_ACCOUNT=your-service-account@your-project.iam.gserviceaccount.com

# Path to the GEE private key JSON file
# Download from the service account key page in GCP console
GEE_KEY_FILE=/app/secrets/gee_service_account_key.json

# GEE project ID (Earth Engine enabled Cloud project)
GEE_PROJECT_ID=your-gcp-project-id

# Sentinel-2 collection to use (Surface Reflectance)
GEE_S2_COLLECTION=COPERNICUS/S2_SR_HARMONIZED

# Cloud masking threshold (0–100 %)
GEE_CLOUD_THRESHOLD=20

# Maximum number of pixels to export per request
GEE_MAX_PIXELS=1e9


# -----------------------------------------------------------------------------
# ML MODEL PATHS
# -----------------------------------------------------------------------------

# Root directory where trained model artefacts are stored
MODEL_DIR=./ml/models/saved

# Path to the TFT + Swin Transformer ensemble model checkpoint
ENSEMBLE_MODEL_PATH=./ml/models/saved/ensemble/tft_swin_ensemble.pt

# Path to the navigability classifier (LightGBM / XGBoost)
NAVIGABILITY_MODEL_PATH=./ml/models/saved/classifier/navigability_classifier.joblib

# Path to the feature scaler used during training
FEATURE_SCALER_PATH=./ml/models/saved/preprocessors/feature_scaler.joblib

# Path to the SHAP explainer artefact
SHAP_EXPLAINER_PATH=./ml/models/saved/explainers/shap_explainer.joblib

# Device to run PyTorch inference on (cpu | cuda | cuda:0)
TORCH_DEVICE=cpu

# Batch size for model inference
INFERENCE_BATCH_SIZE=32


# -----------------------------------------------------------------------------
# NAVIGABILITY THRESHOLDS
# -----------------------------------------------------------------------------

# Minimum depth (metres) for "Navigable" classification
DEPTH_NAVIGABLE_MIN=3.0

# Minimum depth (metres) for "Conditional" classification
DEPTH_CONDITIONAL_MIN=1.5

# Minimum channel width (metres) for "Navigable" classification
WIDTH_NAVIGABLE_MIN=50.0

# Minimum channel width (metres) for "Conditional" classification
WIDTH_CONDITIONAL_MIN=25.0

# Risk score threshold above which a RiskAlert is generated
RISK_ALERT_THRESHOLD=0.7


# -----------------------------------------------------------------------------
# STUDY AREA CONFIGURATION
# -----------------------------------------------------------------------------

# Comma-separated list of supported waterway IDs
SUPPORTED_WATERWAYS=NW-1,NW-2

# Segment length in kilometres used when slicing river centrelines
SEGMENT_LENGTH_KM=5

# NW-1: Ganga — Varanasi to Haldia (approximate bounding box: minLon,minLat,maxLon,maxLat)
NW1_BBOX=83.0,21.5,88.5,25.5

# NW-2: Brahmaputra — Dhubri to Sadiya
NW2_BBOX=89.5,26.5,95.8,28.2

# Coordinate reference system (EPSG code) for spatial operations
CRS_EPSG=4326


# -----------------------------------------------------------------------------
# EXTERNAL APIS & TOKENS
# -----------------------------------------------------------------------------

# Mapbox public token — used for basemap tiles in the frontend
MAPBOX_TOKEN=pk.your_mapbox_token_here

# (Optional) OpenWeatherMap API key for precipitation forecasts
OPENWEATHER_API_KEY=your_openweather_api_key_here

# (Optional) CWC (Central Water Commission) API endpoint
CWC_API_ENDPOINT=https://cwc.gov.in/api/v1

# (Optional) CWC API key
CWC_API_KEY=your_cwc_api_key_here


# -----------------------------------------------------------------------------
# AWS S3 (optional — for artefact and data storage)
# -----------------------------------------------------------------------------

# AWS region
AWS_REGION=ap-south-1

# S3 bucket for storing processed composites and predictions
S3_BUCKET_NAME=aidstl-data

# AWS credentials (prefer IAM roles in production instead of keys)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# S3 key prefix for model artefacts
S3_MODEL_PREFIX=models/saved


# -----------------------------------------------------------------------------
# CORS & SECURITY
# -----------------------------------------------------------------------------

# Comma-separated list of allowed origins for CORS
# Use ["*"] only in development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Whether to allow credentials in CORS requests
ALLOW_CREDENTIALS=True

# Trusted host header values (set to your domain in production)
ALLOWED_HOSTS=localhost,127.0.0.1


# -----------------------------------------------------------------------------
# LOGGING & OBSERVABILITY
# -----------------------------------------------------------------------------

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Log format: json | console
LOG_FORMAT=json

# Log file path (leave empty to log to stdout only)
LOG_FILE=

# Enable Prometheus metrics endpoint at /metrics
ENABLE_METRICS=True

# Prometheus metrics port (exposed by the container)
METRICS_PORT=8001

# (Optional) Sentry DSN for error tracking
SENTRY_DSN=


# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------

# Host to bind the Uvicorn server to
HOST=0.0.0.0

# Port to bind the Uvicorn server to
PORT=8000

# Number of Uvicorn worker processes (production: typically 2*CPU+1)
WORKERS=4

# Keep-alive timeout in seconds
KEEP_ALIVE=5

# Request timeout in seconds
REQUEST_TIMEOUT=120


# -----------------------------------------------------------------------------
# NGINX (docker-compose reverse proxy)
# -----------------------------------------------------------------------------

# Port exposed by the Nginx container on the host
NGINX_PORT=80

# SSL/TLS (set to 443 and add cert paths for HTTPS)
NGINX_SSL_PORT=443


# -----------------------------------------------------------------------------
# FRONTEND (Next.js build args)
# -----------------------------------------------------------------------------

# Public API base URL consumed by the Next.js frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Public Mapbox token (mirrored for Next.js build)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here
